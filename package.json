{
  "name": "planner-v1",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/assemble-site.mjs",
    "build:site": "npm run build",
    "build:capacitor": "tsc -b && vite build --base=./ --outDir dist-capacitor",
    "cap:sync": "npm run build:capacitor && cap sync ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:import && npm run test:sync && npm run test:account && npm run test:calendar && npm run test:auth && npm run test:capacitor",
    "test:import": "node scripts/plannerImport.test.mjs",
    "test:sync": "node --test scripts/syncCore.test.mjs",
    "test:account": "node --test scripts/accountAccess.test.mjs",
    "test:calendar": "node --test scripts/calendarSyncCore.test.mjs scripts/calendarImportPrefs.test.mjs",
    "test:auth": "node --test scripts/authRedirect.test.mjs",
    "test:capacitor": "node --test scripts/capacitorBuild.test.mjs",
    "smoke": "node scripts/smoke.access.mjs",
    "test:e2e": "playwright test",
    "preflight": "npm run lint && npm run test && npm run smoke && npm run build"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.106.2",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
